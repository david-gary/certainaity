# ForenScope runtime configuration
# Copy to .env and fill in site-specific values.  Never commit .env to git.
# All variables use the FORENSCOPE_ prefix (see src/forenscope/config.py).

# ── Infrastructure ───────────────────────────────────────────────────────────
FORENSCOPE_REDIS_URL=redis://localhost:6379/0

# ── File paths ────────────────────────────────────────────────────────────────
FORENSCOPE_OUTPUT_DIR=output
FORENSCOPE_WEIGHTS_DIR=weights

# ── JWT authentication ────────────────────────────────────────────────────────
# RS256 public key used to verify bearer tokens on protected API routes.
# Generate a dev key pair with: python scripts/generate_keys.py
FORENSCOPE_JWT_PUBLIC_KEY_PATH=secrets/jwt_public.pem

# ── Upload limits ─────────────────────────────────────────────────────────────
# Maximum upload size in bytes (default: 50 MB = 52428800)
FORENSCOPE_MAX_FILE_BYTES=52428800

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Maximum POST /v1/analyze requests per unique source IP per minute (default: 60)
FORENSCOPE_RATE_LIMIT_PER_MINUTE=60

# ── Image validation ──────────────────────────────────────────────────────────
FORENSCOPE_MIN_IMAGE_DIMENSION=64
FORENSCOPE_MAX_IMAGE_DIMENSION=20000

# ── Inference ─────────────────────────────────────────────────────────────────
# Decision threshold: overall_confidence > threshold → manipulation_detected
FORENSCOPE_ENSEMBLE_THRESHOLD=0.65
# Force CPU inference even if an NVIDIA GPU is present (useful for local dev)
FORENSCOPE_USE_CPU=false
