# Certainaity runtime configuration
# Copy to .env and fill in site-specific values.  Never commit .env to git.
# All variables use the CERTAINAITY_ prefix (see src/certainaity/config.py).

# ── Infrastructure ───────────────────────────────────────────────────────────
CERTAINAITY_REDIS_URL=redis://localhost:6379/0

# ── File paths ────────────────────────────────────────────────────────────────
CERTAINAITY_OUTPUT_DIR=output
CERTAINAITY_WEIGHTS_DIR=weights

# ── JWT authentication ────────────────────────────────────────────────────────
# RS256 public key used to verify bearer tokens on protected API routes.
# Generate a dev key pair with: python scripts/generate_keys.py
CERTAINAITY_JWT_PUBLIC_KEY_PATH=secrets/jwt_public.pem

# ── Upload limits ─────────────────────────────────────────────────────────────
# Maximum upload size in bytes (default: 50 MB = 52428800)
CERTAINAITY_MAX_FILE_BYTES=52428800

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Maximum POST /v1/analyze requests per unique source IP per minute (default: 60)
CERTAINAITY_RATE_LIMIT_PER_MINUTE=60

# ── Image validation ──────────────────────────────────────────────────────────
CERTAINAITY_MIN_IMAGE_DIMENSION=64
CERTAINAITY_MAX_IMAGE_DIMENSION=20000

# ── Inference ─────────────────────────────────────────────────────────────────
# Decision threshold: overall_confidence > threshold → manipulation_detected
CERTAINAITY_ENSEMBLE_THRESHOLD=0.65
# Force CPU inference even if an NVIDIA GPU is present (useful for local dev)
CERTAINAITY_USE_CPU=false
